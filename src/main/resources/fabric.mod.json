{
    "schemaVersion": 1,
    "id": "lootr_polymer",
    "version": "${version}",
    "name": "LootrPolymer",
    "description": "Server-side polymer wrapper for Lootr.",
    "authors": ["TorNato"],
    "contact": {},
    "license": "MIT",
    "icon": "./icon.png",
    "environment": "server",
    "entrypoints": {
        "main": [
            "tornato.lootr.LootrPolymer"
        ]
    },
    "mixins": [
        "lootrPolymer.mixins.json"
    ],
    "depends": {
        "fabricloader": ">=${loader_version}",
        "fabric-api": "*",
        "minecraft": ">=1.21.11 <1.22",
        "java": ">=21",
        "lootr": "*",
        "polymer-core": "*",
        "polymer-virtual-entity": "*"
    }
}
